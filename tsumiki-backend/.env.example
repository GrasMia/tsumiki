# 应用配置
APP_NAME="tsumiki"
VERSION="0.1.0"
DEBUG=True
SECRET_KEY="your-secret-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS = 15

# 数据库配置
DATABASE_URL="your-database-url"

# 文件存储配置 (本地)
LOCAL_STORAGE_PATH="./wwwroot/files"
LOCAL_AVATAR_PATH="./wwwroot/avatars"

# 文件上传配置 (单位：MB)
UPLOAD_FILE_CHUNK_SIZE=5